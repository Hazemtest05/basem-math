---
/* Native Astro port of the "background shapes" idea: a weighted-random grid of
   little geometric marks (dot / parallel lines / cross / square / diagonal) that
   subtly morph over time. Rebuilt in the site's palette (faint ink + occasional
   red pen on paper) instead of the demo's blue+white, and density-faded toward
   the centre so it never competes with the text. Marks render at BUILD TIME
   (seeded => deterministic, works with zero JS); the optional script only adds
   the gentle "shapes change" animation, and is skipped under reduced motion. */
const W = 1440, H = 900, CELL = 60;

// deterministic seeded PRNG so server + client agree and the pattern is stable
let seed = 20260713;
const rand = () => { seed = (seed * 9301 + 49297) % 233280; return seed / 233280; };

type Shape = 'dot' | 'lines' | 'cross' | 'square' | 'diag';
const SHAPES: Shape[] = ['dot', 'lines', 'cross', 'square', 'diag'];

function mark(shape: Shape, x: number, y: number, c: string, sw = 2): string {
  const cx = x + CELL / 2, cy = y + CELL / 2;
  const a = x + CELL * 0.28, b = x + CELL * 0.72, t = y + CELL * 0.28, d = y + CELL * 0.72;
  const ln = (x1: number, y1: number, x2: number, y2: number) =>
    `<line x1="${x1.toFixed(1)}" y1="${y1.toFixed(1)}" x2="${x2.toFixed(1)}" y2="${y2.toFixed(1)}" stroke="${c}" stroke-width="${sw}"/>`;
  switch (shape) {
    case 'dot': return `<circle cx="${cx}" cy="${cy}" r="${(CELL * 0.09).toFixed(1)}" fill="${c}"/>`;
    case 'lines': return ln(a, t, b, t) + ln(a, cy, b, cy) + ln(a, d, b, d);
    case 'cross': return ln(a, t, b, d) + ln(a, d, b, t);
    case 'square': return `<rect x="${a.toFixed(1)}" y="${t.toFixed(1)}" width="${(b - a).toFixed(1)}" height="${(d - t).toFixed(1)}" fill="none" stroke="${c}" stroke-width="${sw}"/>`;
    case 'diag': return ln(a, d, b, t);
  }
}

const cells: string[] = [];
for (let x = 0; x < W; x += CELL) {
  for (let y = 0; y < H; y += CELL) {
    const fx = Math.abs(x + CELL / 2 - W / 2) / (W / 2); // 0 centre .. 1 edge
    const p = 0.045 + 0.26 * Math.pow(fx, 1.7);          // sparse centre, denser sides
    if (rand() >= p) continue;
    const shape = SHAPES[Math.floor(rand() * SHAPES.length)];
    const accent = rand() < 0.12;
    const c = accent ? 'var(--accent)' : 'var(--ink)';
    const op = accent ? 0.12 : 0.07;
    cells.push(
      `<g class="bsh" data-cell data-x="${x}" data-y="${y}" data-c="${accent ? 'a' : 'i'}" data-op="${op}" style="opacity:${op}">${mark(shape, x, y, c)}</g>`
    );
  }
}
const svg = cells.join('');
---
<div class="bg-shapes" aria-hidden="true">
  <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="xMidYMid slice" set:html={svg} />
</div>

<style>
  .bg-shapes {
    position: fixed;
    inset: 0;
    z-index: var(--z-grid);
    pointer-events: none;
    overflow: hidden;
    /* keep marks off the vertical reading band and softest at the very edges */
    -webkit-mask-image: radial-gradient(120% 90% at 50% 45%, transparent 34%, #000 78%, transparent 100%);
            mask-image: radial-gradient(120% 90% at 50% 45%, transparent 34%, #000 78%, transparent 100%);
  }
  .bg-shapes svg { width: 100%; height: 100%; display: block; }
  .bg-shapes .bsh { transition: opacity 0.9s var(--ease); }
  @media (prefers-reduced-motion: reduce) { .bg-shapes .bsh { transition: none; } }
</style>

<script>
  const layer = document.querySelector('.bg-shapes');
  if (layer && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const CELL = 60;
    const SHAPES = ['dot', 'lines', 'cross', 'square', 'diag'];
    const cells = Array.from(layer.querySelectorAll<SVGGElement>('[data-cell]'));
    const draw = (g: SVGGElement) => {
      const x = +g.dataset.x!, y = +g.dataset.y!;
      const c = g.dataset.c === 'a' ? 'var(--accent)' : 'var(--ink)';
      const cx = x + CELL / 2, cy = y + CELL / 2;
      const a = x + CELL * 0.28, b = x + CELL * 0.72, t = y + CELL * 0.28, d = y + CELL * 0.72;
      const ln = (x1: number, y1: number, x2: number, y2: number) =>
        `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="${c}" stroke-width="2"/>`;
      const shape = SHAPES[Math.floor(Math.random() * SHAPES.length)];
      g.innerHTML =
        shape === 'dot' ? `<circle cx="${cx}" cy="${cy}" r="${CELL * 0.09}" fill="${c}"/>`
        : shape === 'lines' ? ln(a, t, b, t) + ln(a, cy, b, cy) + ln(a, d, b, d)
        : shape === 'cross' ? ln(a, t, b, d) + ln(a, d, b, t)
        : shape === 'square' ? `<rect x="${a}" y="${t}" width="${b - a}" height="${d - t}" fill="none" stroke="${c}" stroke-width="2"/>`
        : ln(a, d, b, t);
    };
    const tick = () => {
      for (let n = 0; n < 2; n++) {
        const g = cells[Math.floor(Math.random() * cells.length)];
        if (!g) continue;
        g.style.opacity = '0';
        setTimeout(() => { draw(g); g.style.opacity = g.dataset.op!; }, 450);
      }
      setTimeout(tick, 2600 + Math.random() * 1800);
    };
    setTimeout(tick, 1600);
  }
</script>
