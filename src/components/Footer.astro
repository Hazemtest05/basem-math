---
import { site } from '@/config/site';
import { teacher, whatsappLink } from '@/config/teacher';
import Icon from '@/components/Icon.astro';
const year = 2026; // static build stamp; update per release
---
<footer class="foot">
  <div class="foot__chalk" aria-hidden="true">
    <svg viewBox="0 0 1200 120" preserveAspectRatio="none" width="100%" height="120">
      <path d="M0 90 C 200 90, 260 30, 420 30 C 560 30, 620 88, 760 88 C 900 88, 980 40, 1200 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.5" stroke-dasharray="2 7" />
    </svg>
  </div>

  <div class="wrap foot__grid">
    <div class="foot__brand">
      <p class="foot__word">{site.slogan}</p>
      <p class="foot__sign">{site.footerSignoff}</p>
    </div>

    <nav class="foot__col" aria-label="روابط">
      <h2 class="foot__h">تصفّح</h2>
      <ul role="list">
        {site.nav.map((item) => (<li><a href={item.href} class="foot__link">{item.label}</a></li>))}
      </ul>
    </nav>

    <div class="foot__col">
      <h2 class="foot__h">تواصل</h2>
      <ul role="list" class="foot__social">
        <li><a href={whatsappLink('مرحباً أستاذ، عندي سؤال في الرياضيات.')} class="foot__link" target="_blank" rel="noopener"><Icon name="whatsapp" size={18} /> واتساب</a></li>
        <li><a href={`mailto:${teacher.email}`} class="foot__link"><Icon name="mail" size={18} /> البريد</a></li>
        {teacher.social.filter((s) => s.icon !== 'whatsapp').map((s) => (
          <li><a href={s.href} class="foot__link" target="_blank" rel="noopener"><Icon name={s.icon} size={18} /> {s.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="foot__col foot__cta-col">
      <h2 class="foot__h">جاهز تبدأ؟</h2>
      <p class="foot__note">أرسل مسألةً واحدة تُحيّرك، ولنرَ كيف تصبح خطوات.</p>
      <a href="/contact" class="btn btn--board">ابدأ من هنا</a>
    </div>
  </div>

  <div class="wrap foot__base">
    <p>© {year} {teacher.brandName}. صُمّم للطلاب، لا لمحرّكات البحث وحدها.</p>
    <p class="foot__meta">{teacher.city}، {teacher.country}</p>
  </div>
</footer>

<style>
  .foot {
    position: relative;
    z-index: var(--z-content);
    margin-block-start: var(--s-10);
    background: var(--board);
    color: var(--chalk);
    padding-block-end: var(--s-6);
  }
  .foot__chalk { color: var(--chalk); margin-block-end: var(--s-6); }
  .foot__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-7) var(--s-6);
    padding-block: var(--s-4) var(--s-8);
  }
  .foot__word { font-size: var(--fs-h2); font-weight: var(--w-thin); line-height: 1.1; }
  .foot__sign { margin-block-start: var(--s-3); color: color-mix(in srgb, var(--accent-bright) 60%, var(--chalk)); font-size: var(--fs-body); }
  .foot__h { font-size: var(--fs-small); color: var(--chalk-2); margin-block-end: var(--s-4); font-weight: var(--w-reg); }
  .foot__col ul { display: grid; gap: var(--s-3); }
  .foot__link { display: inline-flex; align-items: center; gap: var(--s-2); color: var(--chalk); opacity: 0.86; transition: opacity var(--dur-1) var(--ease), color var(--dur-1); }
  .foot__link:hover { opacity: 1; color: var(--accent-bright); }
  .foot__note { color: var(--chalk-2); font-size: var(--fs-small); margin-block-end: var(--s-4); max-width: 32ch; }
  .foot__base {
    display: flex; flex-wrap: wrap; justify-content: space-between; gap: var(--s-3);
    padding-block-start: var(--s-5);
    border-block-start: 1px solid color-mix(in srgb, var(--chalk) 16%, transparent);
    color: var(--chalk-2); font-size: var(--fs-small);
  }

  @media (min-width: 720px) {
    .foot__grid { grid-template-columns: 1.5fr 1fr 1fr 1.4fr; }
    .foot__brand { grid-column: 1; }
  }
</style>
