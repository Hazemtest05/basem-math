---
/* A small, consistent inline-SVG icon set. Vanilla-Astro has no icon library;
   these are a single curated family (stroke 1.75, 24-grid) used site-wide.
   Brand glyphs (whatsapp/telegram/youtube) are simple recognizable marks. */
interface Props {
  name:
    | 'menu' | 'close' | 'arrow' | 'check' | 'spark' | 'external'
    | 'whatsapp' | 'telegram' | 'youtube' | 'instagram' | 'facebook'
    | 'mail' | 'phone' | 'compass' | 'play' | 'refresh';
  size?: number;
  class?: string;
}
const { name, size = 22, class: cls = '' } = Astro.props;
const stroke = 'currentColor';
const sw = 1.75;
const brand = ['whatsapp', 'telegram', 'youtube', 'instagram', 'facebook'].includes(name);
---
<svg
  class:list={['icon', cls]}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={brand ? stroke : 'none'}
  stroke={brand ? 'none' : stroke}
  stroke-width={sw}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {name === 'menu' && <><line x1="3" y1="7" x2="21" y2="7" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="17" x2="21" y2="17" /></>}
  {name === 'close' && <><line x1="6" y1="6" x2="18" y2="18" /><line x1="18" y1="6" x2="6" y2="18" /></>}
  {name === 'arrow' && <><line x1="20" y1="12" x2="4" y2="12" /><polyline points="10 6 4 12 10 18" /></>}
  {name === 'check' && <polyline points="20 6 9 17 4 12" />}
  {name === 'spark' && <path d="M12 3v6M12 15v6M3 12h6M15 12h6M6.5 6.5l3 3M14.5 14.5l3 3M17.5 6.5l-3 3M9.5 14.5l-3 3" />}
  {name === 'external' && <><path d="M14 4h6v6" /><line x1="20" y1="4" x2="11" y2="13" /><path d="M18 14v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h5" /></>}
  {name === 'compass' && <><circle cx="12" cy="12" r="9" /><polygon points="15.5 8.5 10.5 10.5 8.5 15.5 13.5 13.5" /></>}
  {name === 'play' && <polygon points="7 5 19 12 7 19 7 5" />}
  {name === 'refresh' && <><path d="M21 12a9 9 0 1 1-3-6.7" /><polyline points="21 3 21 8 16 8" /></>}
  {name === 'mail' && <><rect x="3" y="5" width="18" height="14" rx="2" /><polyline points="3 7 12 13 21 7" /></>}
  {name === 'phone' && <path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z" />}

  {name === 'whatsapp' && <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91C21.95 6.45 17.5 2 12.04 2zm5.8 14.05c-.25.69-1.44 1.32-1.98 1.36-.53.05-1.02.24-3.44-.72-2.9-1.14-4.74-4.1-4.88-4.29-.14-.19-1.16-1.54-1.16-2.94s.73-2.09 1-2.37c.26-.29.57-.36.76-.36.19 0 .38 0 .55.01.18.01.42-.07.65.5.25.6.84 2.08.91 2.23.07.15.12.32.02.51-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.76 1.25 1.63 2.02 1.12 1 2.07 1.31 2.36 1.46.29.15.46.12.63-.07.17-.19.73-.85.92-1.14.19-.29.39-.24.65-.15.26.1 1.66.78 1.95.93.29.15.48.22.55.34.07.12.07.69-.18 1.38z" />}
  {name === 'telegram' && <path d="M21.94 4.5 18.6 20.2c-.25 1.1-.9 1.37-1.83.86l-5.05-3.72-2.44 2.35c-.27.27-.5.5-1 .5l.36-5.14L18.05 6.5c.4-.36-.09-.56-.63-.2L6.65 13.2 1.7 11.65c-1.08-.34-1.1-1.08.23-1.6l19.32-7.45c.9-.34 1.68.2 1.39 1.6z" />}
  {name === 'youtube' && <path d="M23 12s0-3.2-.41-4.73a2.5 2.5 0 0 0-1.77-1.77C19.29 5.1 12 5.1 12 5.1s-7.29 0-8.82.4A2.5 2.5 0 0 0 1.41 7.27C1 8.8 1 12 1 12s0 3.2.41 4.73a2.5 2.5 0 0 0 1.77 1.77c1.53.4 8.82.4 8.82.4s7.29 0 8.82-.4a2.5 2.5 0 0 0 1.77-1.77C23 15.2 23 12 23 12zM9.75 15.02V8.98L15 12l-5.25 3.02z" />}
  {name === 'instagram' && <path d="M12 2c2.72 0 3.06.01 4.12.06 1.07.05 1.8.22 2.43.47.66.25 1.22.6 1.77 1.15.55.55.9 1.11 1.15 1.77.25.63.42 1.36.47 2.43.05 1.06.06 1.4.06 4.12s-.01 3.06-.06 4.12c-.05 1.07-.22 1.8-.47 2.43-.25.66-.6 1.22-1.15 1.77-.55.55-1.11.9-1.77 1.15-.63.25-1.36.42-2.43.47-1.06.05-1.4.06-4.12.06s-3.06-.01-4.12-.06c-1.07-.05-1.8-.22-2.43-.47a4.9 4.9 0 0 1-1.77-1.15 4.9 4.9 0 0 1-1.15-1.77c-.25-.63-.42-1.36-.47-2.43C2.01 15.06 2 14.72 2 12s.01-3.06.06-4.12c.05-1.07.22-1.8.47-2.43.25-.66.6-1.22 1.15-1.77.55-.55 1.11-.9 1.77-1.15.63-.25 1.36-.42 2.43-.47C8.94 2.01 9.28 2 12 2zm0 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 8.2A3.2 3.2 0 1 1 12 8.8a3.2 3.2 0 0 1 0 6.4zM17.2 5.6a1.2 1.2 0 1 0 0 2.4 1.2 1.2 0 0 0 0-2.4z" />}
  {name === 'facebook' && <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z" />}
</svg>
<style>
  .icon { display: inline-block; flex: 0 0 auto; }
</style>
