---
/* Procedural SVG motif per curriculum unit. Small, ink-stroked, one accent
   stroke. viewBox 0 0 48 48. No raster, no stock. */
import type { MotifKey } from '@/data/curriculum';
interface Props { motif: MotifKey; size?: number; class?: string; }
const { motif, size = 48, class: cls = '' } = Astro.props;
---
<svg class:list={['glyph', cls]} width={size} height={size} viewBox="0 0 48 48"
  fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <!-- baseline axes shared by many motifs -->
  {['staircase','asymptote','tangent','converge','logcurve','expcurve','area','complexplane'].includes(motif) && (
    <g class="glyph__axes" stroke-width="1.1" opacity="0.45"><line x1="8" y1="40" x2="42" y2="40" /><line x1="10" y1="6" x2="10" y2="42" /></g>
  )}
  {motif === 'staircase' && <polyline points="10 36 18 36 18 28 26 28 26 20 34 20 34 12 42 12" class="accent" />}
  {motif === 'asymptote' && <>
    <line x1="10" y1="14" x2="42" y2="14" stroke-dasharray="3 3" opacity="0.6" />
    <path d="M12 38 C 22 37, 28 24, 40 16" class="accent" />
  </>}
  {motif === 'tangent' && <>
    <path d="M10 34 Q 24 6 40 30" />
    <line x1="14" y1="30" x2="40" y2="12" class="accent" />
    <circle cx="24" cy="16.7" r="2.4" class="accent" fill="var(--accent)" stroke="none" />
  </>}
  {motif === 'converge' && <>
    <line x1="10" y1="22" x2="42" y2="22" stroke-dasharray="3 3" opacity="0.55" />
    <polyline points="12 34 18 14 24 27 30 19 36 23 42 22" class="accent" />
  </>}
  {motif === 'logcurve' && <path d="M12 38 C 14 22, 20 16, 42 12" class="accent" />}
  {motif === 'expcurve' && <path d="M10 40 C 26 40, 34 30, 40 8" class="accent" />}
  {motif === 'area' && <>
    <path d="M10 34 Q 24 8 40 30" />
    <path d="M12 40 L 12 33 Q 24 10 38 30 L 38 40 Z" fill="var(--accent-wash-2)" stroke="none" />
    <g stroke="var(--accent)" opacity="0.5" stroke-width="1"><line x1="16" y1="40" x2="16" y2="30" /><line x1="22" y1="40" x2="22" y2="22" /><line x1="28" y1="40" x2="28" y2="21" /><line x1="34" y1="40" x2="34" y2="27" /></g>
  </>}
  {motif === 'axes3d' && <>
    <line x1="24" y1="42" x2="24" y2="8" />
    <line x1="24" y1="42" x2="8" y2="34" />
    <line x1="24" y1="42" x2="42" y2="34" />
    <line x1="24" y1="42" x2="34" y2="16" class="accent" />
    <polygon points="34 16 31 18 34 20" fill="var(--accent)" stroke="none" />
  </>}
  {motif === 'angle' && <>
    <line x1="12" y1="36" x2="40" y2="36" />
    <line x1="12" y1="36" x2="36" y2="14" class="accent" />
    <path d="M28 36 A 16 16 0 0 0 24.5 27" stroke-width="1.2" />
  </>}
  {motif === 'plane' && <>
    <polygon points="8 30 26 20 40 26 22 36" stroke-width="1.3" />
    <line x1="16" y1="33" x2="34" y2="17" class="accent" />
    <circle cx="24" cy="27" r="1.8" fill="var(--accent)" stroke="none" />
  </>}
  {motif === 'complexplane' && <>
    <line x1="24" y1="8" x2="24" y2="40" stroke-width="1.1" opacity="0.45" />
    <line x1="34" y1="18" x2="24" y2="26" class="accent" />
    <path d="M24 26 L 30 26" opacity="0" />
    <path d="M31 26 A 7 7 0 0 0 27.5 20" stroke-width="1.1" />
    <circle cx="34" cy="18" r="2.3" fill="var(--accent)" stroke="none" />
  </>}
  {motif === 'rotation' && <>
    <circle cx="24" cy="24" r="13" stroke-dasharray="2.5 3" opacity="0.5" />
    <line x1="24" y1="24" x2="35" y2="18" class="accent" />
    <path d="M33 11 A 13 13 0 0 1 37 22" class="accent" />
    <polygon points="37 22 39 17 33.5 19" fill="var(--accent)" stroke="none" />
  </>}
  {motif === 'tree' && <>
    <circle cx="24" cy="9" r="2" fill="currentColor" stroke="none" />
    <line x1="24" y1="11" x2="14" y2="22" /><line x1="24" y1="11" x2="34" y2="22" class="accent" />
    <line x1="14" y1="24" x2="9" y2="36" /><line x1="14" y1="24" x2="19" y2="36" />
    <line x1="34" y1="24" x2="29" y2="36" class="accent" /><line x1="34" y1="24" x2="39" y2="36" />
    <g fill="currentColor" stroke="none"><circle cx="14" cy="23" r="1.7" /><circle cx="34" cy="23" r="1.7" /><circle cx="9" cy="38" r="1.6" /><circle cx="19" cy="38" r="1.6" /><circle cx="29" cy="38" r="1.6" /><circle cx="39" cy="38" r="1.6" /></g>
  </>}
  {motif === 'dice' && <>
    <rect x="10" y="10" width="28" height="28" rx="6" />
    <g fill="var(--accent)" stroke="none"><circle cx="18" cy="18" r="2" /><circle cx="30" cy="18" r="2" /><circle cx="24" cy="24" r="2" /><circle cx="18" cy="30" r="2" /><circle cx="30" cy="30" r="2" /></g>
  </>}
</svg>
<style>
  .glyph { color: var(--ink); }
  .glyph .accent { stroke: var(--accent); }
</style>
