---
import { problems } from '@/data/problems';
import Formula from '@/components/Math.astro';
import MarginNote from '@/components/MarginNote.astro';
import Icon from '@/components/Icon.astro';
---
<section class="probs section" aria-labelledby="probs-title">
  <div class="wrap">
    <header class="probs__head" data-reveal>
      <h2 id="probs-title" class="h2 thin">مسائل مختارة، محلولة كما تُكتب في الامتحان.</h2>
      <p class="lead measure">أمثلة حقيقية من منهاج البكالوريا، بالخطوات والتبرير والخطأ الذي يجب تجنّبه.</p>
    </header>

    <div class="probs__list">
      {problems.map((p) => (
        <article class="prob" data-reveal>
          <div class="prob__aside">
            <span class="tag">{p.unitTag}</span>
            <span class="prob__id num">{p.id}</span>
          </div>
          <div class="prob__main">
            <h3 class="prob__title">{p.title}</h3>
            <p class="prob__statement">{p.statement}</p>
            {p.statementLatex && <span class="formula-plate"><Formula tex={p.statementLatex} block /></span>}

            <ol class="prob__steps" role="list">
              {p.steps.map((st, j) => (
                <li class="prob__step">
                  <span class="prob__step-n num" aria-hidden="true">{j + 1}</span>
                  <span class="prob__step-body">
                    <Formula tex={st.latex} />
                    {st.note && <span class="prob__step-note">{st.note}</span>}
                  </span>
                </li>
              ))}
            </ol>

            <p class="prob__answer-lead"><Icon name="check" size={16} /> الجواب</p>
            <span class="prob__answer"><Formula tex={p.answerLatex} block /></span>

            <MarginNote type="mistake" class="prob__mistake">{p.mistake}</MarginNote>

            <p class="prob__takeaway"><span class="prob__takeaway-tag">الخلاصة</span>{p.takeaway}</p>
            <p class="prob__source">{p.source}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .probs__head { max-width: 54ch; margin-block-end: var(--s-8); }
  .probs__list { display: grid; gap: var(--s-8); }
  .prob {
    display: grid; grid-template-columns: 1fr; gap: var(--s-5);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background: var(--raised); border: 1px solid var(--line); border-radius: var(--r-card);
  }
  .prob__aside { display: flex; align-items: center; justify-content: space-between; gap: var(--s-3); }
  .prob__id { color: var(--ink-3); font-size: var(--fs-small); }
  .prob__title { font-size: var(--fs-h2); font-weight: var(--w-thin); }
  .prob__statement { margin-block-start: var(--s-3); color: var(--ink-2); }
  .prob__steps { display: grid; gap: var(--s-4); margin-block: var(--s-5); }
  .prob__step { display: grid; grid-template-columns: auto 1fr; gap: var(--s-4); align-items: start; }
  .prob__step-n {
    inline-size: 1.7rem; block-size: 1.7rem; border-radius: var(--r-pill);
    background: var(--paper-2); color: var(--ink-2); display: grid; place-items: center; font-size: var(--fs-small);
  }
  .prob__step-body { display: grid; gap: var(--s-1); min-width: 0; overflow-x: auto; }
  .prob__step-note { color: var(--ink-2); font-size: var(--fs-small); }
  .prob__answer-lead { display: inline-flex; align-items: center; gap: var(--s-2); color: var(--ok); font-size: var(--fs-small); }
  .prob__answer-lead :global(.icon) { color: var(--ok); }
  .prob__answer { display: block; }
  .prob__mistake { margin-block-start: var(--s-5); }
  .prob__takeaway { margin-block-start: var(--s-5); color: var(--ink-2); }
  .prob__takeaway-tag { display: inline-block; color: var(--ink); margin-inline-end: var(--s-2); }
  .prob__takeaway-tag::after { content: ':'; }
  .prob__source { margin-block-start: var(--s-4); color: var(--ink-3); font-size: var(--fs-micro); }

  @media (min-width: 860px) {
    .prob { grid-template-columns: 0.28fr 0.72fr; gap: var(--s-7); align-items: start; }
    .prob__aside { flex-direction: column; align-items: flex-start; position: sticky; top: 88px; }
  }
</style>
